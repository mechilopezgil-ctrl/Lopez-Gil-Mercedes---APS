    "\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "\n",
    "ax.plot(Frec, xx_db, color='blue', linewidth=1.8, linestyle='none', marker = 'o',\n",
    "        label=r'$s$ (analog)')\n",
    "\n",
    "ax.set_title(\"\")\n",
    "ax.set_xlabel(\"Frecuencia [Hz]\")\n",
    "ax.set_ylabel(\"Densidad de Potencia [dB]\")\n",
